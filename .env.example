# Copy to .env and fill in real values: cp .env.example .env

# Required
SECRET_KEY=change_me_use_openssl_rand_hex_32
OPENAI_API_KEY=sk-...

# Optional
LLM_MODEL=gpt-4o
ENVIRONMENT=development
DEBUG=true
DEFAULT_HEADLESS=false
RATE_LIMIT_PER_MINUTE=60

# Default admin user (created by init_db.py)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# Optional automation credentials
# LOGIN_EMAIL=
# LOGIN_PASSWORD=
